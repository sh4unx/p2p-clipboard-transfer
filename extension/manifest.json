{
  "manifest_version": 3,
  "name": "P2P",
  "version": "3.0.0",
  "description": "Transfer images from phone to PC + sync clipboard text across devices — all in one.",
  "permissions": [
    "clipboardWrite",
    "clipboardRead",
    "downloads",
    "notifications",
    "storage",
    "offscreen",
    "tabs",
    "alarms",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.firebaseio.com/*",
    "https://*.firebasedatabase.app/*",
    "https://*.firebase.com/*",
    "https://*.firebaseapp.com/*",
    "https://*.googleapis.com/*",
    "https://*.web.app/*",
    "https://api.qrserver.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
