{
  "name": "P2P \u2014 Wireless Transfer",
  "short_name": "P2P",
  "description": "Transfer images and sync clipboard between phone and PC.",
  "start_url": "/?utm_source=pwa",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#070d1a",
  "theme_color": "#070d1a",
  "categories": [
    "utilities",
    "productivity"
  ],
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "scope": "/",
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+p2p",
      "url": "/?code=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "handle_links": "preferred"
}